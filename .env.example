MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_CHAIN_ID=10143

# Preferred MONSKILLS wallet path. Generate with:
# cast wallet new ~/.monskills/keystore --unsafe-password ""
MONSKILLS_KEYSTORE_DIR=~/.monskills/keystore
MONSKILLS_KEYSTORE_FILE=

# Contract addresses after deployment.
AGENT_REGISTRY_ADDRESS=
TREASURY_DECISION_REGISTRY_ADDRESS=

# Optional live parallel demo wallets. Use three funded MON testnet keystore files.
PARALLEL_MONSKILLS_KEYSTORE_FILES=
# Faster hackathon fallback when Foundry/cast keystores are unavailable.
# Use three funded testnet burner private keys. Never commit real keys.
PARALLEL_PRIVATE_KEYS=
PARALLEL_RECORD_DECISION_GAS_LIMIT=650000

# Fallback only for throwaway local/testnet burner flows. Do not commit real keys.
PRIVATE_KEY=

LLM_PROVIDER=openrouter
LLM_API_KEY=
LLM_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MAX_TOKENS=1200
LLM_RETRY_ATTEMPTS=3
